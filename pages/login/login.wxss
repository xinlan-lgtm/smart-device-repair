/* pages/login/login.wxss - 角色选择页样式 */
.login-page {
  min-height: 100vh;
  background-color: #F5F7FA;
  display: flex;
  flex-direction: column;
  padding: 0 40rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 80rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: #9CA3AF;
}

.role-cards {
  display: flex;
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.role-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
}

.role-card.active {
  border-color: #1A56DB;
  background-color: #EEF2FF;
}

.role-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.role-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 22rpx;
  color: #9CA3AF;
}

.login-btn-area {
  padding: 0 40rpx;
}
