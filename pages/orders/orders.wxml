<!-- pages/orders/orders.wxml - 工单列表页 -->
<view class="page-container">
  <!-- 状态筛选栏 -->
  <scroll-view class="filter-tabs" scroll-x>
    <view
      wx:for="{{statusTabs}}"
      wx:key="key"
      class="filter-tab {{activeTab === item.key ? 'active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >
      {{item.label}}
    </view>
  </scroll-view>

  <!-- 工单列表 -->
  <block wx:if="{{!loading && orders.length > 0}}">
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="card order-card"
      data-id="{{item.id}}"
      bindtap="onOrderTap"
    >
      <!-- 卡片头部：工单号 + 状态标签 -->
      <view class="order-header">
        <text class="order-id">{{item.id}}</text>
        <view class="status-badge" style="background-color: {{item.statusColor}}20; color: {{item.statusColor}};">
          {{item.statusLabel}}
        </view>
      </view>
      <!-- 设备信息 -->
      <view class="order-device">
        <text class="device-name">{{item.deviceName}}</text>
        <text class="device-code">{{item.deviceCode}}</text>
      </view>
      <!-- 故障简述 -->
      <view class="order-desc text-ellipsis">{{item.faultDesc}}</view>
      <!-- 底部：时间 -->
      <view class="order-footer">
        <text class="order-time">{{item.timeText}}</text>
        <text class="order-arrow">›</text>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view wx:if="{{!loading && orders.length === 0}}" class="empty-state">
    <text>📋</text>
    <text>暂无工单</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text>加载中...</text>
  </view>
</view>
