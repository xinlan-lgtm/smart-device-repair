<!-- pages/mine/mine.wxml - 个人中心页 -->
<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar">
      <text wx:if="{{isAdmin}}">🔧</text>
      <text wx:else>👷</text>
    </view>
    <text class="user-name">{{userInfo ? userInfo.name : '未登录'}}</text>
    <text class="user-role">{{isAdmin ? '管理员' : '工人'}}</text>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="onSwitchRole">
      <text class="menu-icon">🔄</text>
      <text class="menu-label">切换身份</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于系统</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
