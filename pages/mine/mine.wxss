/* pages/mine/mine.wxss - 个人中心页样式 */
.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
  background-color: #1A56DB;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.avatar text {
  font-size: 56rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-role {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  background-color: rgba(255, 255, 255, 0.15);
  padding: 4rpx 24rpx;
  border-radius: 20rpx;
}

.menu-list {
  margin: 0 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  background-color: #FFFFFF;
  margin-bottom: 2rpx;
}

.menu-item:first-child {
  border-radius: 16rpx 16rpx 0 0;
}

.menu-item:last-child {
  border-radius: 0 0 16rpx 16rpx;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CBD5E1;
}
