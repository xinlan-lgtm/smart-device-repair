/* pages/ai-result/ai-result.wxss - AI分析结果页样式 */

/* ===== 头部 ===== */
.result-header {
  text-align: center;
  padding: 40rpx 24rpx;
}

.result-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.result-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.result-subtitle {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ===== 卡片标题 ===== */
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

/* ===== 故障类型 ===== */
.fault-type {
  font-size: 32rpx;
  color: #1F2937;
  font-weight: 600;
  line-height: 1.6;
}

/* ===== 紧急程度 ===== */
.urgency-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.urgency-badge {
  padding: 10rpx 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

.confidence-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ===== 维修建议 ===== */
.suggestion-text {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* ===== 报修信息确认 ===== */
.summary-card {
  background-color: #F9FAFB;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.summary-item:last-child {
  border-bottom: none;
}

.summary-label {
  font-size: 26rpx;
  color: #9CA3AF;
  flex-shrink: 0;
  width: 140rpx;
}

.summary-value {
  font-size: 26rpx;
  color: #1F2937;
  font-weight: 500;
  text-align: right;
  flex: 1;
}

.summary-desc {
  font-weight: 400;
  color: #4B5563;
  line-height: 1.6;
}

/* ===== 操作按钮 ===== */
.action-area {
  padding: 24rpx;
  padding-bottom: 48rpx;
}
